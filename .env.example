# ==========================================
# Railway.app Environment Variables
# ==========================================
# Copia este archivo a .env en producción
# Y actualiza los valores según tu BD de Railway

# Base de Datos MySQL (Railway proporciona estos valores)
DB_HOST=db.railway.internal
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASS=tu_password_aqui

# Desarrollo Local (XAMPP)
# DB_HOST=localhost
# DB_NAME=technical_db
# DB_USER=root
# DB_PASS=

# Aplicación
APP_ENV=production
APP_DEBUG=false
